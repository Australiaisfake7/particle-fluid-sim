{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug OpenGL Project",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/main.exe",
            "preLaunchTask": "Build Debug",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            // If this fails, set miDebuggerPath to your gdb.exe location e.g. C:/msys64/ucrt64/bin/gdb.exe
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Run OpenGL Project",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/main.exe",
            "preLaunchTask": "Build Release",
            "args": [],
            "cwd": "${workspaceFolder}",
            "environment": []
        }
    ]
}